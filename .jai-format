spaces_inside_parens                        true
spaces_inside_brackets                      true
spaces_inside_literals                      true
spaces_around_operators                     true
space_after_cast                            true

braces_on_new_line                          true
quick_lambda_brace_on_new_line              false
else_on_new_line                            true

struct_literal_dot_mode                     FORCE 

single_statement_brace_mode                 DONT_MODIFY
single_statement_line_mode                  SAME_LINE
single_statement_double_space               false
insert_space_in_single_line_comments        true
keep_whitespace_before_single_line_comments true

surround_multiple_returns_with_parens       false

# indent_width                          1
# indent_mode                           TABS
max_empty_lines_to_keep                     1
indent_case                                 false
tab_width                                   4
indent_width                                4
indent_mode                                 SPACES
no_carriage_return_on_windows               false

alignment_mode                              EXACT
# alignment_mode                              INDENT_ONLY
# brackets_alignment_mode                     EXACT 
# struct_literal_alignment_mode               EXACT 

multiline_array_literal_end_on_new_line     false 
multiline_struct_literal_end_on_new_line    false 
